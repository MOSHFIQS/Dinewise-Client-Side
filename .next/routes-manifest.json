    },
    {
      "page": "/dashboard/myCart",
      "regex": "^/dashboard/myCart(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/myCart(?:/)?$"
    },
    {
      "page": "/dashboard/myMenu",
      "regex": "^/dashboard/myMenu(?:/)?$",
