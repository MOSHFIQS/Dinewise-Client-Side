    },
    {
      "page": "/dashboard/audit",
      "regex": "^/dashboard/audit(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/audit(?:/)?$"
    },
    {
      "page": "/dashboard/categories",
      "regex": "^/dashboard/categories(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/categories(?:/)?$"
    },
    {
      "page": "/dashboard/coupons",
      "regex": "^/dashboard/coupons(?:/)?$",
